{
  "name": "@wptp/matrix",
  "version": "0.1.0",
  "description": "WPTP public compatibility matrix (source x target x verification grade)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theorem6/wptp-matrix.git"
  },
  "bin": {
    "wptp-compose": "./dist/compose-cli.js",
    "wptp-verify-harness": "./dist/verify-harness-cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "compose": "tsx src/compose-cli.ts",
    "verify:harness": "tsx src/verify-harness-cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate": "tsx src/cli-validate.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compose": {
      "types": "./dist/compose.d.ts",
      "import": "./dist/compose.js"
    }
  },
  "dependencies": {
    "@wptp/adapter-browser": "file:../wptp-adapter-browser",
    "@wptp/adapter-openapi": "file:../wptp-adapter-openapi",
    "@wptp/emit-nextjs": "file:../wptp-emit-nextjs",
    "@wptp/ir": "file:../wptp-ir"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.22.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  }
}
